{
  "schema_version": 1,
  "canvas_schema_version": "theme-canvas-v1",
  "fingerprint_schema_version": "theme-fingerprint-v1",
  "preview_renderer_version": "html-preview-v1",
  "placements": [
    "dominant_surface",
    "secondary_surface",
    "elevated_surface",
    "primary_text",
    "secondary_text",
    "muted_text",
    "selection_fill",
    "selection_text",
    "focus_indicator",
    "border_separator",
    "control_fill",
    "control_hover",
    "control_pressed",
    "control_disabled",
    "status_error",
    "status_success",
    "status_warning",
    "link_info",
    "accent_candidate"
  ],
  "terminal_fallbacks": {
    "selection_background": ["color4", "color12", "background"],
    "selection_foreground": ["background", "foreground"],
    "cursor": ["foreground"],
    "cursor_text_color": ["background"],
    "color8": ["color0", "background"],
    "color9": ["color1"],
    "color10": ["color2"],
    "color11": ["color3"],
    "color12": ["color4"],
    "color13": ["color5"],
    "color14": ["color6"],
    "color15": ["color7", "foreground"]
  },
  "kvantum_fallbacks": {
    "GeneralColors.alt.base.color": ["GeneralColors.base.color", "GeneralColors.window.color"],
    "GeneralColors.window.text.color": ["GeneralColors.text.color"],
    "GeneralColors.button.text.color": ["GeneralColors.text.color"],
    "GeneralColors.disabled.text.color": ["GeneralColors.text.color"],
    "GeneralColors.tooltip.text.color": ["GeneralColors.text.color"],
    "GeneralColors.highlight.text.color": ["GeneralColors.text.color"],
    "GeneralColors.inactive.highlight.color": ["GeneralColors.highlight.color"],
    "GeneralColors.link.visited.color": ["GeneralColors.link.color"],
    "GeneralColors.progress.indicator.text.color": ["GeneralColors.highlight.text.color", "GeneralColors.text.color"],
    "GeneralColors.mid.light.color": ["GeneralColors.light.color"],
    "GeneralColors.mid.color": ["GeneralColors.button.color", "GeneralColors.base.color"],
    "GeneralColors.dark.color": ["GeneralColors.mid.color", "GeneralColors.base.color"]
  },
